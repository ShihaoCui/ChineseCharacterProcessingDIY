import pandas as pd

txt_file = "input.txt"
excel_file = "output.xlsx"

df = pd.read_csv(txt_file, sep="\t", header=None, encoding="utf-8")

print("前5行数据：")
print(df.head())
print("列数：", df.shape[1])

if df.shape[1] == 3500:
    df.columns = ["排名", "汉字", "频次", "占比1", "占比2", "拼音", "释义"]

df.to_excel(excel_file, index=False)

print(f"转换完成：{excel_file}")